# Copy to config/aesthetic-v4.env, then fill the private key locally.
PANGU_BASE_URL=http://43.139.21.243:4000
PANGU_API_KEY=
PANGU_JUDGE_MODEL=claude-opus-4-7-thinking
PANGU_JUDGE_PROMPT_VERSION=aesthetic-v4
PANGU_JUDGE_OUTPUT_MODE=full
PANGU_JUDGE_TIMEOUT=360
PANGU_JUDGE_MAX_TOKENS=1200

# Optional PackyAPI provider for local comparison only; not the handoff default.
PACKY_BASE_URL=https://www.packyapi.com/v1
PACKY_API_KEY=
PACKY_JUDGE_MODEL=gpt-5.5
PACKY_JUDGE_PROMPT_VERSION=aesthetic-v4
PACKY_JUDGE_OUTPUT_MODE=full
PACKY_JUDGE_TIMEOUT=240
PACKY_JUDGE_MAX_COMPLETION_TOKENS=1200
PACKY_IMAGE_DETAIL=high

# Run controls.
AESTHETIC_V4_BACKEND=model
AESTHETIC_V4_MODEL_PROVIDER=pangu
AESTHETIC_V4_WORKERS=1
AESTHETIC_V4_MANIFEST_VIEWPORT=mobile
AESTHETIC_V4_VIEWPORT=mobile
AESTHETIC_V4_VIEWPORT_SELECTION=auto
AESTHETIC_V4_AGGREGATE_STRATEGY=min
# Daily fast mode is first_view. Use fullpage only when explicitly validating scroll/page-complete issues.
AESTHETIC_V4_SCREENSHOT_MODE=first_view
AESTHETIC_V4_FULLPAGE_MAX_HEIGHT=12000
AESTHETIC_V4_ADAPTIVE_VIEWPORTS=off
AESTHETIC_V4_SCORE_BREAKDOWN=on
AESTHETIC_V4_DESIGNER_REVIEW=off
AESTHETIC_V4_FORMAL_REPORT=0

# Not configurable: occlusion/overlap checking is always on.
AESTHETIC_V4_OCCLUSION_OVERLAP_CHECK=always_on
